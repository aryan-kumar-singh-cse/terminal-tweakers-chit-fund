model Group {\n  id           Int           @id @default(autoincrement())\n  name         String\n  createdBy    String\n  monthlyAmount Float\n  duration     Int\n  members      Member[]      @relation("GroupMembers", onDelete: CASCADE)\n  contributions Contribution[] @relation("GroupContributions", onDelete: CASCADE)\n  auctions      Auction[]      @relation("GroupAuctions", onDelete: CASCADE)\n}\n\nmodel Member {\n  id              Int              @id @default(autoincrement())\n  groupId        Int\n  name            String\n  email           String\n  group          Group        @relation("GroupMembers", fields: [groupId], references: [id], onDelete: CASCADE)\n  contributions   Contribution[] @relation("MemberContributions", onDelete: CASCADE)\n  auctionWins     Auction[]      @relation("MemberAuctionWins", onDelete: CASCADE)\n}\n\nmodel Contribution {\n  id       Int  @id @default(autoincrement())\n  groupId  Int\n  memberId Int\n  amount   Float\n  month    Int\n  year     Int\n  group    Group     @relation("GroupContributions", fields: [groupId], references: [id], onDelete: CASCADE)\n  member   Member    @relation("MemberContributions", fields: [memberId], references: [id], onDelete: CASCADE)\n}\n\nmodel Auction {\n  id       Int  @id @default(autoincrement())\n  groupId  Int\n  winnerId Int\n  amount   Float\n  cycle    Int\n  group    Group   @relation("GroupAuctions", fields: [groupId], references: [id], onDelete: CASCADE)\n  winner   Member  @relation("MemberAuctionWins", fields: [winnerId], references: [id], onDelete: CASCADE)\n}